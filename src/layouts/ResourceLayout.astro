---
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import Breadcrumbs from "../components/layout/Breadcrumbs.astro";
import BaseLayout from "./BaseLayout.astro";

interface Props {
  entry: CollectionEntry<"resources">;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const canonicalPath = `/resources/${entry.id}/`;
const breadcrumbSchema = {
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://www.blueriverhomecare.com/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Resources",
      item: "https://www.blueriverhomecare.com/resources/",
    },
    {
      "@type": "ListItem",
      position: 3,
      name: entry.data.title,
      item: `https://www.blueriverhomecare.com${canonicalPath}`,
    },
  ],
};
---

<BaseLayout
  title={entry.data.seoTitle}
  description={entry.data.description}
  canonicalPath={canonicalPath}
  pageType="article"
  schema={breadcrumbSchema}
>
  <section class="page-hero resource-hero" data-cta-threshold>
    <div class="narrow-container">
      <Breadcrumbs
        items={[
          { label: "Home", href: "/" },
          { label: "Resources", href: "/resources/" },
          { label: entry.data.title },
        ]}
      />
      <p class="eyebrow">{entry.data.eyebrow}</p>
      <h1>{entry.data.title}</h1>
      <p class="lead">{entry.data.description}</p>
      <span class="reading-time">{entry.data.readingTime}</span>
    </div>
  </section>
  <article class="section article-body">
    <div class="article-container">
      <Content />
    </div>
  </article>
</BaseLayout>
