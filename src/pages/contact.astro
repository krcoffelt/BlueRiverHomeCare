---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/layout/Breadcrumbs.astro";
import ContactForm from "../components/forms/ContactForm.astro";
import contactImage from "../assets/scraped/consultation-support.jpg";
import { site } from "../data/site";
---

<BaseLayout
  title="Contact Our Belton Home Care Team"
  description="Call Chris Jennen at Blue River Home Care in Belton, MO, about private-pay companionship, in-home care, scheduling, and possible funding sources."
  hideCtaBand
>
  <section class="page-hero compact-page-hero" data-cta-threshold>
    <div class="container">
      <Breadcrumbs
        items={[{ label: "Home", href: "/" }, { label: "Contact" }]}
      />
      <p class="eyebrow">Contact</p>
      <h1>Tell Chris what has changed at home.</h1>
      <p class="lead">
        Start with the part of the day that worries you most and what the family
        is already doing. You do not need a diagnosis or finished care plan.
      </p>
    </div>
  </section>

  <section
    class="section contact-section"
    aria-labelledby="contact-options-title"
  >
    <div class="container">
      <div class="section-heading">
        <h2 id="contact-options-title">Choose the easiest way to begin.</h2>
        <p>A phone call is usually the fastest path to a useful answer.</p>
      </div>
      <div class="contact-details contact-details-grid">
        <div>
          <p class="eyebrow">Call Chris</p>
          <p>Chris Jennen, Director of Operations</p>
          <a class="contact-large-link" href={site.phoneMainHref}
            >{site.phoneMainFormatted}</a
          >
        </div>
        <div>
          <p class="eyebrow">Email</p><a href={`mailto:${site.email}`}
            >{site.email}</a
          >
        </div>
        <div>
          <p class="eyebrow">Office</p><address>{site.officeAddress}</address><a
            class="text-link"
            href={site.mapUrl}
            target="_blank"
            rel="noreferrer">Open in Google Maps</a
          >
        </div>
        <div>
          <p class="eyebrow">Consultation</p>
          <p>Free by phone or in person.</p>
          <a class="text-link" href="/consultation/">Plan a conversation</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section alt" aria-labelledby="contact-form-title">
    <div class="container contact-form-feature">
      <div class="media-frame inner-notched-media contact-form-media">
        <Image
          src={contactImage}
          alt="Family discussing home care support together"
          widths={[700, 1000, 1500]}
          sizes="(max-width: 940px) 100vw, 45vw"
        />
        <div class="media-caption">
          <p class="eyebrow">No finished care plan needed</p>
          <h2 id="contact-form-title">
            Start with the part of the day that worries you.
          </h2>
        </div>
      </div>
      <ContactForm />
    </div>
  </section>
</BaseLayout>
