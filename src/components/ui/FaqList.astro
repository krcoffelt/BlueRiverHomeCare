---
interface Faq {
  question: string;
  answer: string;
}

interface Props {
  items: Faq[];
}

const { items } = Astro.props;
---

<div class="faq-list">
  {
    items.map((faq) => (
      <details>
        <summary>{faq.question}</summary>
        <p>{faq.answer}</p>
      </details>
    ))
  }
</div>
