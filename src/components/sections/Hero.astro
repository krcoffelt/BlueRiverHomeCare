---
import type { ImageMetadata } from "astro";
import { Picture } from "astro:assets";
import Button from "../ui/Button.astro";
import { site } from "../../data/site";

interface Props {
  image: ImageMetadata;
  imageAlt?: string;
  eyebrow: string;
  title: string;
  body: string;
  trustLine?: string;
}

const { image, imageAlt = "", eyebrow, title, body, trustLine } = Astro.props;
---

<section class="hero" data-cta-threshold aria-labelledby="home-title">
  <div class="hero-media" aria-hidden={imageAlt ? undefined : "true"}>
    <Picture
      src={image}
      alt={imageAlt}
      loading="eager"
      fetchpriority="high"
      widths={[720, 1080, 1440, 2000, 2500]}
      formats={["avif", "webp"]}
      sizes="100vw"
    />
    <div class="hero-scrim"></div>
  </div>
  <div class="hero-content">
    <div class="hero-copy">
      <p class="brand-kicker">{site.name}</p>
      <p class="kicker">{eyebrow}</p>
      <h1 id="home-title">{title}</h1>
      <p>{body}</p>
      <div class="hero-actions">
        <Button href="/consultation/">Schedule a Free Consultation</Button>
        <Button href={site.phoneMainHref} variant="secondary">Call Chris</Button
        >
      </div>
      {trustLine && <p class="hero-trust">{trustLine}</p>}
    </div>
  </div>
</section>
