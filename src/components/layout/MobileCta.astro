---
import { CalendarDays, MessageSquareText, Phone } from "@lucide/astro";
import { site } from "../../data/site";

const currentPath = Astro.url.pathname;
const isInquiryPage = ["/consultation/", "/contact/"].includes(currentPath);
const inquiryHref =
  currentPath === "/contact/"
    ? "#contact-form-title"
    : "#consultation-form-title";
---

<aside class="mobile-cta" data-mobile-cta aria-label="Quick contact actions">
  <a href={site.phoneMainHref}>
    <Phone size={19} aria-hidden="true" />
    <span>Call Chris</span>
  </a>
  <a href={isInquiryPage ? inquiryHref : "/consultation/"}>
    {
      isInquiryPage ? (
        <MessageSquareText size={19} aria-hidden="true" />
      ) : (
        <CalendarDays size={19} aria-hidden="true" />
      )
    }
    <span>{isInquiryPage ? "Inquiry Form" : "Consultation"}</span>
  </a>
</aside>

<script is:inline>
  (() => {
    const bar = document.querySelector("[data-mobile-cta]");
    const threshold = document.querySelector("[data-cta-threshold]");
    if (!bar) return;

    if (!threshold) {
      bar.classList.add("is-visible");
      return;
    }

    const observer = new IntersectionObserver(
      ([entry]) => bar.classList.toggle("is-visible", !entry.isIntersecting),
      { threshold: 0 },
    );
    observer.observe(threshold);
  })();
</script>
